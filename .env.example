# Copy this file to .env and fill in your values. .env is gitignored.

# --- Required ---
COURTLISTENER_API_TOKEN=   # 40-char token from courtlistener.com/help/api-access
ANTHROPIC_API_KEY=         # sk-ant-... from console.anthropic.com

# --- Gmail drafts (needed for --gmail flag) ---
# One-time OAuth setup: see README "Gmail OAuth setup" section.
GMAIL_CLIENT_ID=           # ...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=       # GOCSPX-...
GMAIL_REFRESH_TOKEN=       # 1//...
TEST_MAILBOX=              # the Gmail address drafts go to, e.g. you+test@gmail.com
